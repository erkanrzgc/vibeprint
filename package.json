{
  "name": "vibeprint",
  "description": "Chrome extension that scans the current page on demand for signals it was built with an AI coding tool or no-code AI app builder.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:e2e": "wxt build --mode e2e",
    "test:e2e": "npm run build:e2e && playwright test",
    "capture": "node tools/capture/capture.mjs",
    "eval": "vite-node tools/eval/evaluate.ts",
    "eval:coverage": "vite-node tools/eval/coverage.ts",
    "postinstall": "wxt prepare",
    "store:shots": "npm run build:e2e && node tools/store/screenshots.mjs",
    "store:zip": "wxt zip"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@wxt-dev/module-react": "^1.1.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
