    "bodyTextSample": "{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Gift My Book\",\"url\":\"https://giftmybook.com\",\"logo\":\"https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/68611ccc92873ca4f3b8cb70/15e655bb2_0132977bd_ChatGPTImageAug14202512_50_39PM2.png\",\"sameAs\":[\"https://www.instagram.com/giftmybook/\",\"https://www.facebook.com/61579638652884/\",\"https://www.youtube.com/channel/UCvJpQygQj9NIU9KHEemrJZQ\"]} :root { --primary: #016241; --primary-hover: #004d33; --cream: #FCFAF7; /* Fonts: Lora for headings, Inter for everything else */ --serif: 'Lora', serif; --sans: 'Inter', sans-serif; --serif-display: 'Lora', serif; --serif-body: 'Lora', serif; } .font-serif { font-family: var(--serif); } .font-sans { font-family: var(--sans); } .font-serif-display { font-family: var(--serif-display); } .font-serif-body { font-family: var(--serif-body); } /* H1: Lora (serif) for premium/literary hero feel */ h1 { font-family: var(--serif); font-weight: 700; } /* H2–H6: Inter (sans) for clean, modern section headings */ h2, h3, h4, h5, h6 { font-family: var(--sans); } h2, h3 { font-weight: 700; } h4, h5, h6 { font-weight: 600; } /* Default body/UI font: Inter */ body, input, textarea, select, button, label { font-family: var(--sans); } /* Inputs: accessible placeholders and legible defaults */ input, textarea, select { font-size: 0.95rem; /* keep close to existing proportions */ line-height: 1.45; } input::placeholder, textarea::placeholder { color: #6b7280; /* slate-500 for better contrast */ opacity: 1; /* ensure visibility */ } /* Improve touch responsiveness on mobile */ .touch-manipulation { touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none; } /* Ensure buttons are always clickable */ button { cursor: pointer; -webkit-tap-highlight-color: transparent; } button:disabled { cursor: not-allowed; } .bg-primary { background-color: var(--primary); } .bg-cream { background-color: var(--cream); } .text-primary { color: v"
